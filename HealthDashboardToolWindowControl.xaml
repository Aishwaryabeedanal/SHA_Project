<UserControl x:Class="SHA_Project.HealthDashboardToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="420"
             Name="MyToolWindow">

    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- HEADER ROW -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="ScanButton"
                            Content="🔍 Scan Solution"
                            Width="160"
                            Height="35"
                            Click="ScanButton_Click"
                            Background="#0078D4"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"/>
                    <TextBlock x:Name="LastScannedText"
                               Text=""
                               Foreground="#888888"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </StackPanel>

                <!-- MCP COMMAND BOX -->
                <TextBlock Text="MCP Command:"
                           Foreground="#9CDCFE"
                           FontSize="12"
                           Margin="0,5,0,3"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">
                    <TextBox x:Name="CommandInput"
                             Width="200"
                             Height="30"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             KeyDown="CommandInput_KeyDown"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderBrush="#0078D4"
                             Text=""/>
                    <Button Content="▶ Run"
                            Width="60"
                            Height="30"
                            Margin="5,0,0,0"
                            Click="RunCommand_Click"
                            Background="#0078D4"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- HEALTH SCORE -->
                <Border CornerRadius="6"
                        Padding="10"
                        Margin="0,0,0,10">
                    <Border.Background>
                        <SolidColorBrush x:Name="ScoreBorderColor"
                                         Color="#1E3A1E"/>
                    </Border.Background>
                    <TextBlock x:Name="ScoreText"
                               Text="Health Score: -- (Not Scanned)"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#4EC94E"/>
                </Border>

                <!-- STATS ROW -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">

                    <Border Background="#3A1E1E"
                            CornerRadius="5"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="ErrorsText"
                                   Text="❌ Errors: 0"
                                   Foreground="#F44747"
                                   FontSize="13"
                                   FontWeight="Bold"/>
                    </Border>

                    <Border Background="#3A2E1E"
                            CornerRadius="5"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <TextBlock x:Name="WarningsText"
                                   Text="⚠ Warnings: 0"
                                   Foreground="#FFA500"
                                   FontSize="13"
                                   FontWeight="Bold"/>
                    </Border>

                    <Border Background="#1E2A3A"
                            CornerRadius="5"
                            Padding="10,6">
                        <TextBlock x:Name="TodoText"
                                   Text="📝 TODOs: 0"
                                   Foreground="#9CDCFE"
                                   FontSize="13"
                                   FontWeight="Bold"/>
                    </Border>

                </StackPanel>

                <!-- NUGET PACKAGES -->
                <TextBlock Text="📦 NuGet Packages"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#9CDCFE"
                           Margin="0,0,0,6"/>

                <ListView x:Name="PackagesList"
                          Height="100"
                          Background="#1E1E1E"
                          Foreground="White"
                          BorderBrush="#0078D4"
                          Margin="0,0,0,12"/>

                <!-- PACKAGE DETAILS -->
                <TextBlock Text="📋 Package Details"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#9CDCFE"
                           Margin="0,0,0,5"/>

                <Border Background="#1E1E1E"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="PackageDetailsText"
                               Text="Select a package to view details."
                               TextWrapping="Wrap"
                               Foreground="#D4D4D4"
                               FontSize="12"/>
                </Border>

                <!-- BUILD ISSUES -->
                <TextBlock Text="🔨 Build Issues"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#F44747"
                           Margin="0,0,0,5"/>

                <Border Background="#1E1E1E"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="BuildIssuesText"
                               Text="No build issues found."
                               TextWrapping="Wrap"
                               Foreground="#F44747"
                               FontSize="12"/>
                </Border>

                <!-- TODO COMMENTS -->
                <TextBlock Text="📝 TODO Comments"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#9CDCFE"
                           Margin="0,0,0,5"/>

                <Border Background="#1E1E1E"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="TodoDetailsText"
                               Text="No TODO comments found."
                               TextWrapping="Wrap"
                               Foreground="#9CDCFE"
                               FontSize="12"/>
                </Border>

                <!-- AI INSIGHT -->
                <TextBlock Text="🤖 AI Insights (Gemini)"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#4EC94E"
                           Margin="0,0,0,5"/>

                <Border Background="#1E2A1E"
                        CornerRadius="5"
                        Padding="10"
                        Margin="0,0,0,12">
                    <TextBlock x:Name="AiInsightText"
                               Text="No AI insights yet. Click Scan to analyze."
                               TextWrapping="Wrap"
                               Foreground="#4EC94E"
                               FontSize="12"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>