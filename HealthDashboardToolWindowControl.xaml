<UserControl x:Class="SHA_Project.HealthDashboardToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             Name="MyToolWindow">
    <Grid Margin="10">

        <StackPanel>

            <Button x:Name="ScanButton"
                Content="Scan Solution"
                Width="160"
                Height="35"
                Margin="0,0,0,15"
                Click="ScanButton_Click"/>

            <TextBlock x:Name="ErrorsText"
                   Text="Errors: 0"
                   FontSize="16"
                   Margin="0,5"/>

            <TextBlock x:Name="WarningsText"
                   Text="Warnings: 0"
                   FontSize="16"
                   Margin="0,5"/>

            <TextBlock x:Name="TodoText"
                   Text="TODOs: 0"
                   FontSize="16"
                   Margin="0,5"/>

            <TextBlock x:Name="ScoreText"
                   Text="Health Score: 100"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,15"/>

            <TextBlock Text="NuGet Packages"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,20,0,10"/>

            <ListView x:Name="PackagesList"
                  Height="80"/>

            <TextBlock Text="Package Details"
           FontSize="18"
           FontWeight="Bold"
           Margin="0,15,0,5"/>

            <TextBlock x:Name="PackageDetailsText"
           Text="Select a package to view details."
           TextWrapping="Wrap"
           FontSize="12"
           Margin="0,2"/>

            <TextBlock Text="Build Issues"
           FontSize="18"
           FontWeight="Bold"
           Margin="0,10,0,5"/>

            <TextBlock x:Name="BuildIssuesText"
           Text="No build issues found."
           TextWrapping="Wrap"
           FontSize="12"
           Margin="0,2"/>

            <TextBlock Text="AI Insight"
           FontSize="18"
           FontWeight="Bold"
           Margin="0,10,0,5"/>

            <TextBlock x:Name="AiInsightText"
           Text="No AI insights yet."
           TextWrapping="Wrap"/>

        </StackPanel>

    </Grid>
</UserControl>
